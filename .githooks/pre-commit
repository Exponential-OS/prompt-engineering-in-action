#!/usr/bin/env bash
# .githooks/pre-commit — plugin-user-content-gate
#
# Blocks commits that introduce user-specific content into plugin SKILL.md
# files. Product definitions must be generic; user config belongs in
# bootstrap adapters (~/.codialectic/context.json, workspace CLAUDE.md).
#
# Install:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GATE="${HOME}/cyborg/rules/plugin-user-content-gate/HOW.sh"

# Only run gate if SKILL.md files are staged
staged_skills=$(git diff --cached --name-only | grep -E "plugins/.*/SKILL\.md" || true)
if [[ -z "$staged_skills" ]]; then
  exit 0
fi

if [[ ! -f "$GATE" ]]; then
  echo "⚠ plugin-user-content-gate: HOW.sh not found at ${GATE} — skipping check" >&2
  exit 0
fi

result=$(bash "$GATE" "${REPO_ROOT}" 2>/dev/null)
verdict=$(echo "$result" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('verdict','WARN'))" 2>/dev/null || echo "WARN")

if [[ "$verdict" == "BLOCK" ]]; then
  echo ""
  echo "❌ COMMIT BLOCKED — plugin-user-content-gate"
  echo ""
  echo "Plugin SKILL.md files contain user-specific content."
  echo "Product definitions must be generic (distributed to all users)."
  echo ""
  echo "Violations:"
  echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for v in d.get('violations', []):
    print(f\"  {v['file']}:{v['line']} — {v['description']}\")
    print(f\"    content: {v['content'][:100]}\")
" 2>/dev/null || echo "$result"
  echo ""
  echo "Remediation:"
  echo "  • Replace hardcoded paths with /path/to/... placeholders or {workspace_root}"
  echo "  • Replace personal domains/repos with generic examples (your-org/your-repo)"
  echo "  • User-specific bootstrap config → ~/.codialectic/context.json"
  echo "  • See: ~/cyborg/rules/plugin-user-content-gate/README.md"
  echo ""
  exit 1
fi

exit 0
